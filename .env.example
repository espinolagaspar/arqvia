# ── Admin de proyectos ────────────────────────────────────────────────────────
# Contraseña para entrar a /admin (elegí una fuerte).
ADMIN_PASSWORD=

# Secreto para firmar la cookie de sesión. Generá uno aleatorio, ej:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Si no lo definís, se deriva de ADMIN_PASSWORD (menos seguro).
SESSION_SECRET=

# ── Vercel Blob ─────────────────────────────────────────────────────────────────
# Token del Blob store. En Vercel se inyecta solo al conectar el store al proyecto.
# Para desarrollo local copialo de: Vercel > Storage > tu Blob store > .env.local
BLOB_READ_WRITE_TOKEN=
